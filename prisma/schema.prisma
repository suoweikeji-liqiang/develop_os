generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum RequirementStatus {
  DRAFT
  IN_REVIEW
  CONSENSUS
  IMPLEMENTING
  DONE
}

enum RequirementStabilityLevel {
  S0_IDEA
  S1_ROUGHLY_DEFINED
  S2_MAIN_FLOW_CLEAR
  S3_ALMOST_READY
  S4_READY_FOR_DEVELOPMENT
  S5_VERIFIED_STABLE
}

enum RequirementUnitStatus {
  DRAFT
  REFINING
  AGREED
  READY_FOR_DESIGN
  READY_FOR_DEV
  ARCHIVED
}

enum IssueUnitSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueUnitStatus {
  OPEN
  TRIAGED
  IN_PROGRESS
  WAITING_CONFIRMATION
  RESOLVED
  REJECTED
  ARCHIVED
}

enum Role {
  PRODUCT
  DEV
  TEST
  UI
  EXTERNAL
}

enum NotificationType {
  MENTION
  STATUS_CHANGE
  COMMENT
}

enum ConflictStatus {
  OPEN
  DISMISSED
  RESOLVED
}

enum ConflictScope {
  INTERNAL
  CROSS_REQUIREMENT
}

enum ConflictSeverity {
  LOW
  MEDIUM
  HIGH
}

enum ClarificationSessionStatus {
  OPEN
  CLOSED
}

enum ClarificationQuestionCategory {
  GOAL
  SCOPE
  USER
  IO
  CONSTRAINT
  ACCEPTANCE
  RISK
  OTHER
}

enum ClarificationQuestionStatus {
  OPEN
  ANSWERED
  RESOLVED
  SKIPPED
}

enum SpecArtifactFormat {
  markdown
  json
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  name           String
  isAdmin        Boolean         @default(false)
  roles          UserRole[]
  sessions       Session[]
  signoffs       ReviewSignoff[]
  comments       Comment[]
  mentions       Mention[]
  notifications  Notification[]
  webhookConfig  WebhookConfig?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  role   Role
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Invite {
  id        String    @id @default(cuid())
  email     String
  roles     Role[]
  token     String    @unique
  invitedBy String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
}

model Requirement {
  id            String                @id @default(cuid())
  title         String
  rawInput      String                @db.Text
  model         Json?
  citations     Json?                 @default("[]")
  confidence    Json?
  status        RequirementStatus     @default(DRAFT)
  stabilityLevel     RequirementStabilityLevel @default(S0_IDEA)
  stabilityScore     Int?
  stabilityReason    String?               @db.Text
  stabilityUpdatedAt DateTime?
  stabilityUpdatedBy String?
  tags          String[]              @default([])
  attempts      Int                   @default(1)
  version       Int                   @default(1)
  createdBy     String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  conversations ConversationMessage[]
  versions      RequirementVersion[]
  signoffs      ReviewSignoff[]
  comments              Comment[]
  notifications         Notification[]
  externalSubmission    ExternalSubmission?
  conflicts             RequirementConflict[] @relation("RequirementConflicts")
  relatedConflicts      RequirementConflict[] @relation("RelatedRequirementConflicts")
  testCaseSuites        RequirementTestCaseSuite[]
  clarificationSessions ClarificationSession[]
  modelChangeLogs       ModelChangeLog[]
  specArtifacts         SpecArtifact[]
  requirementUnits      RequirementUnit[]
  issueUnits            IssueUnit[]

  @@index([status])
  @@index([stabilityLevel])
  @@index([createdBy])
  @@index([createdAt])
}

model RequirementUnit {
  id               String                    @id @default(cuid())
  requirementId    String
  parentUnitId     String?
  unitKey          String
  title            String
  summary          String                    @db.Text
  layer            String
  status           RequirementUnitStatus     @default(DRAFT)
  stabilityLevel   RequirementStabilityLevel @default(S0_IDEA)
  stabilityScore   Int?
  stabilityReason  String?                   @db.Text
  sourceType       String?
  sourceRef        String?
  acceptanceNotes  String?                   @db.Text
  ownerId          String?
  sortOrder        Int                       @default(0)
  createdBy        String
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  requirement      Requirement               @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  parentUnit       RequirementUnit?          @relation("RequirementUnitParent", fields: [parentUnitId], references: [id], onDelete: SetNull)
  childUnits       RequirementUnit[]         @relation("RequirementUnitParent")
  issueUnits       IssueUnit[]               @relation("IssueUnitPrimaryRequirementUnit")

  @@unique([requirementId, unitKey])
  @@index([requirementId, sortOrder])
  @@index([requirementId, layer, status])
  @@index([requirementId, stabilityLevel])
  @@index([parentUnitId])
  @@index([ownerId])
}

model IssueUnit {
  id                       String            @id @default(cuid())
  requirementId            String
  primaryRequirementUnitId String?
  type                     String
  severity                 IssueUnitSeverity @default(MEDIUM)
  title                    String
  description              String            @db.Text
  status                   IssueUnitStatus   @default(OPEN)
  blockDev                 Boolean           @default(false)
  sourceType               String?
  sourceRef                String?
  suggestedResolution      String?           @db.Text
  resolvedNote             String?           @db.Text
  ownerId                  String?
  createdBy                String
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  requirement              Requirement       @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  primaryRequirementUnit   RequirementUnit?  @relation("IssueUnitPrimaryRequirementUnit", fields: [primaryRequirementUnitId], references: [id], onDelete: SetNull)

  @@index([requirementId, status, updatedAt])
  @@index([requirementId, severity, status])
  @@index([requirementId, blockDev, status])
  @@index([primaryRequirementUnitId])
  @@index([ownerId])
}

model ClarificationSession {
  id            String                     @id @default(cuid())
  requirementId String
  status        ClarificationSessionStatus @default(OPEN)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  requirement   Requirement                @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  questions     ClarificationQuestion[]

  @@index([requirementId, createdAt])
}

model ClarificationQuestion {
  id           String                      @id @default(cuid())
  sessionId    String
  category     ClarificationQuestionCategory
  questionText String
  status       ClarificationQuestionStatus @default(OPEN)
  answerText   String?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  session      ClarificationSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([category])
}

model ModelChangeLog {
  id           String   @id @default(cuid())
  requirementId String
  changeSource String
  patchJson    Json
  rationale    String?
  confidence   Float?
  evidenceRefs Json?
  createdAt    DateTime @default(now())

  requirement  Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId, createdAt])
  @@index([requirementId, changeSource, createdAt])
}

model SpecArtifact {
  id            String           @id @default(cuid())
  requirementId String
  version       Int
  format        SpecArtifactFormat
  content       String           @db.Text
  createdAt     DateTime         @default(now())

  requirement   Requirement      @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId, createdAt])
  @@unique([requirementId, version])
}

model RequirementTestCaseSuite {
  id                     String      @id @default(cuid())
  requirementId          String
  sourceRequirementVersion Int
  suite                  Json
  generatedBy            String
  agentId                String      @default("test-case-generator")
  createdAt              DateTime    @default(now())

  requirement            Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId, createdAt])
  @@index([requirementId, sourceRequirementVersion])
}

model RequirementVersion {
  id            String      @id @default(cuid())
  requirementId String
  version       Int
  model         Json
  confidence    Json?
  changeSource  String      @default("manual") // "manual" | "ai-structure" | "ai-converse" | "assumption"
  createdBy     String
  createdAt     DateTime    @default(now())

  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([requirementId, version])
  @@index([requirementId, createdAt])
}

model ConversationMessage {
  id            String      @id @default(cuid())
  requirementId String
  role          String      // "user" | "assistant"
  content       Json        // UIMessage parts array
  createdAt     DateTime    @default(now())

  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId, createdAt])
}

model ReviewSignoff {
  id            String      @id @default(cuid())
  requirementId String
  role          Role
  userId        String
  checklist     Json        // { items: [{ key: string, label: string, checked: boolean }] }
  signedAt      DateTime    @default(now())

  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])

  @@unique([requirementId, role])
  @@index([requirementId])
}

model Comment {
  id            String    @id @default(cuid())
  requirementId String
  authorId      String
  content       String    @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  requirement   Requirement    @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id])
  mentions      Mention[]
  notifications Notification[]

  @@index([requirementId, createdAt])
  @@index([authorId])
}

model Mention {
  id        String  @id @default(cuid())
  commentId String
  userId    String

  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id])

  @@unique([commentId, userId])
  @@index([userId])
}

model Notification {
  id            String           @id @default(cuid())
  userId        String
  type          NotificationType
  read          Boolean          @default(false)
  requirementId String?
  commentId     String?
  createdAt     DateTime         @default(now())

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  requirement   Requirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  comment       Comment?     @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

model WebhookConfig {
  id        String   @id @default(cuid())
  userId    String   @unique
  url       String
  secret    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExternalSubmission {
  id               String      @id @default(cuid())
  token            String      @unique
  requirementId    String      @unique
  submitterName    String
  submitterContact String?
  createdAt        DateTime    @default(now())

  requirement      Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
}

model KnowledgeDocument {
  id         String   @id @default(cuid())
  name       String
  mimeType   String
  status     String   @default("PROCESSING")
  chunkCount Int?
  uploadedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CodeRepository {
  id                   String    @id @default(cuid())
  owner                String
  repo                 String
  githubTokenEncrypted String
  lastSyncedAt         DateTime?
  addedBy              String
  createdAt            DateTime  @default(now())

  @@unique([owner, repo, addedBy])
}

model KnowledgeChunk {
  id         String                     @id @default(cuid())
  sourceType String
  sourceId   String
  sourceName String
  content    String                     @db.Text
  embedding  Unsupported("vector(1536)")?
  metadata   Json                       @default("{}")
  createdAt  DateTime                   @default(now())

  @@index([sourceType, sourceId])
}

model RequirementConflict {
  id                   String           @id @default(cuid())
  requirementId        String
  relatedRequirementId String?
  fingerprint          String
  status               ConflictStatus   @default(OPEN)
  scope                ConflictScope
  severity             ConflictSeverity
  title                String
  summary              String           @db.Text
  rationale            String           @db.Text
  recommendedAction    String           @db.Text
  evidence             Json             @default("[]")
  resolutionNote       String?          @db.Text
  reviewedAt           DateTime?
  agentId              String           @default("conflict-detector")
  lastDetectedAt       DateTime         @default(now())
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  requirement          Requirement      @relation("RequirementConflicts", fields: [requirementId], references: [id], onDelete: Cascade)
  relatedRequirement   Requirement?     @relation("RelatedRequirementConflicts", fields: [relatedRequirementId], references: [id], onDelete: SetNull)

  @@unique([requirementId, fingerprint])
  @@index([requirementId, status, updatedAt])
  @@index([relatedRequirementId])
}
