generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum RequirementStatus {
  DRAFT
  IN_REVIEW
  CONSENSUS
  IMPLEMENTING
  DONE
}

enum Role {
  PRODUCT
  DEV
  TEST
  UI
  EXTERNAL
}

enum NotificationType {
  MENTION
  STATUS_CHANGE
  COMMENT
}

enum ConflictStatus {
  OPEN
  DISMISSED
  RESOLVED
}

enum ConflictScope {
  INTERNAL
  CROSS_REQUIREMENT
}

enum ConflictSeverity {
  LOW
  MEDIUM
  HIGH
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  name           String
  isAdmin        Boolean         @default(false)
  roles          UserRole[]
  sessions       Session[]
  signoffs       ReviewSignoff[]
  comments       Comment[]
  mentions       Mention[]
  notifications  Notification[]
  webhookConfig  WebhookConfig?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  role   Role
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Invite {
  id        String    @id @default(cuid())
  email     String
  roles     Role[]
  token     String    @unique
  invitedBy String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
}

model Requirement {
  id            String                @id @default(cuid())
  title         String
  rawInput      String                @db.Text
  model         Json?
  citations     Json?                 @default("[]")
  confidence    Json?
  status        RequirementStatus     @default(DRAFT)
  tags          String[]              @default([])
  attempts      Int                   @default(1)
  version       Int                   @default(1)
  createdBy     String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  conversations ConversationMessage[]
  versions      RequirementVersion[]
  signoffs      ReviewSignoff[]
  comments              Comment[]
  notifications         Notification[]
  externalSubmission    ExternalSubmission?
  conflicts             RequirementConflict[] @relation("RequirementConflicts")
  relatedConflicts      RequirementConflict[] @relation("RelatedRequirementConflicts")

  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
}

model RequirementVersion {
  id            String      @id @default(cuid())
  requirementId String
  version       Int
  model         Json
  confidence    Json?
  changeSource  String      @default("manual") // "manual" | "ai-structure" | "ai-converse" | "assumption"
  createdBy     String
  createdAt     DateTime    @default(now())

  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([requirementId, version])
  @@index([requirementId, createdAt])
}

model ConversationMessage {
  id            String      @id @default(cuid())
  requirementId String
  role          String      // "user" | "assistant"
  content       Json        // UIMessage parts array
  createdAt     DateTime    @default(now())

  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId, createdAt])
}

model ReviewSignoff {
  id            String      @id @default(cuid())
  requirementId String
  role          Role
  userId        String
  checklist     Json        // { items: [{ key: string, label: string, checked: boolean }] }
  signedAt      DateTime    @default(now())

  requirement   Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])

  @@unique([requirementId, role])
  @@index([requirementId])
}

model Comment {
  id            String    @id @default(cuid())
  requirementId String
  authorId      String
  content       String    @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  requirement   Requirement    @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id])
  mentions      Mention[]
  notifications Notification[]

  @@index([requirementId, createdAt])
  @@index([authorId])
}

model Mention {
  id        String  @id @default(cuid())
  commentId String
  userId    String

  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id])

  @@unique([commentId, userId])
  @@index([userId])
}

model Notification {
  id            String           @id @default(cuid())
  userId        String
  type          NotificationType
  read          Boolean          @default(false)
  requirementId String?
  commentId     String?
  createdAt     DateTime         @default(now())

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  requirement   Requirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  comment       Comment?     @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

model WebhookConfig {
  id        String   @id @default(cuid())
  userId    String   @unique
  url       String
  secret    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExternalSubmission {
  id               String      @id @default(cuid())
  token            String      @unique
  requirementId    String      @unique
  submitterName    String
  submitterContact String?
  createdAt        DateTime    @default(now())

  requirement      Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
}

model KnowledgeDocument {
  id         String   @id @default(cuid())
  name       String
  mimeType   String
  status     String   @default("PROCESSING")
  chunkCount Int?
  uploadedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CodeRepository {
  id                   String    @id @default(cuid())
  owner                String
  repo                 String
  githubTokenEncrypted String
  lastSyncedAt         DateTime?
  addedBy              String
  createdAt            DateTime  @default(now())

  @@unique([owner, repo, addedBy])
}

model KnowledgeChunk {
  id         String                     @id @default(cuid())
  sourceType String
  sourceId   String
  sourceName String
  content    String                     @db.Text
  embedding  Unsupported("vector(1536)")?
  metadata   Json                       @default("{}")
  createdAt  DateTime                   @default(now())

  @@index([sourceType, sourceId])
}

model RequirementConflict {
  id                   String           @id @default(cuid())
  requirementId        String
  relatedRequirementId String?
  fingerprint          String
  status               ConflictStatus   @default(OPEN)
  scope                ConflictScope
  severity             ConflictSeverity
  title                String
  summary              String           @db.Text
  rationale            String           @db.Text
  recommendedAction    String           @db.Text
  evidence             Json             @default("[]")
  resolutionNote       String?          @db.Text
  reviewedAt           DateTime?
  agentId              String           @default("conflict-detector")
  lastDetectedAt       DateTime         @default(now())
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  requirement          Requirement      @relation("RequirementConflicts", fields: [requirementId], references: [id], onDelete: Cascade)
  relatedRequirement   Requirement?     @relation("RelatedRequirementConflicts", fields: [relatedRequirementId], references: [id], onDelete: SetNull)

  @@unique([requirementId, fingerprint])
  @@index([requirementId, status, updatedAt])
  @@index([relatedRequirementId])
}
