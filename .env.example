# Docker database settings
POSTGRES_DB=devos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# App runtime settings (localhost for host development; docker-compose overrides DATABASE_URL to use db host)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devos?schema=public
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-64-char-hex-string

# AI provider settings
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Embedding settings (set provider according to your available API keys)
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DEEPSEEK_EMBEDDING_MODEL=text-embedding-3-small
